      object REWhatsNew: TRichEdit
        Left = 0
        Top = 23
        Width = 377
        Height = 279
        Align = alClient
        Font.Charset = ANSI_CHARSET
        Font.Color = clWindowText
        Font.Height = -12
        Font.Name = 'Segoe UI'
        Font.Style = []
        Lines.Strings = (
          'Tutorial 7: Multithreading and Pad Availability'
          '(Concept diagram under Wavescope)'
          'From:'
          'https://gstreamer.freedesktop.org/documentation/tutorials/basic/'
          'mul'
          'tithreading-and-pad-availability.html'
          ''
          'New concepts:'
          '1. Request Pads - pads created on demand'
          '   (tee element: src template)'
          '2. TGstPadRef.RequestFrom() to get a   request pad from an '
          'element'
          '3. TGstPadRef.ReleaseFrom() to release   it when done'
          '4. queue element creates a new thread  for each branch'
          '5. Pipeline has 3 threads:'
          '   - main (audiotestsrc + tee)'
          '   - audio branch (queue -> sink)'
          '   - video branch (queue -> wavescope -> autovideosink)'
          '6. Trackbar controls audiotestsrc  frequency live')
        ParentFont = False
        ReadOnly = True
        ScrollBars = ssVertical
        TabOrder = 0
      end
    end
